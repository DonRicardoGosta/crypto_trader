# Másold .env névre: cp .env.example .env
# A docker compose automatikusan betölti a gyökérben lévő .env fájlt.

SECRETS_MASTER_KEY=dev-master-key-change-in-production-32b

# Böngészőből (host) — frontend build argok
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8001/realtime

# Ha a 5173 foglalt (régi konténerek): állítsd 5175-re, vagy futtasd make docker-clean
FRONTEND_HOST_PORT=5173

# Opcionális: helyi Python futtatáshoz (Dockerben a compose állítja)
DATABASE_URL=postgresql+asyncpg://trading:trading@localhost:5432/trading
KAFKA_BOOTSTRAP=localhost:19092
REDIS_URL=redis://localhost:6380/0
